{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "gcc-debug",
      "inherits": "base",
      "displayName": "GCC debug",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "gcc-sanitizers",
      "inherits": "gcc-debug",
      "displayName": "GCC ASan and UBSan",
      "cacheVariables": {
        "PROTOCOL_STACK_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "clang-debug",
      "inherits": "base",
      "displayName": "Clang debug",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "clang-sanitizers",
      "inherits": "clang-debug",
      "displayName": "Clang ASan and UBSan",
      "cacheVariables": {
        "PROTOCOL_STACK_ENABLE_SANITIZERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug"
    },
    {
      "name": "gcc-sanitizers",
      "configurePreset": "gcc-sanitizers"
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug"
    },
    {
      "name": "clang-sanitizers",
      "configurePreset": "clang-sanitizers"
    }
  ],
  "testPresets": [
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "gcc-sanitizers",
      "configurePreset": "gcc-sanitizers",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "clang-sanitizers",
      "configurePreset": "clang-sanitizers",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
